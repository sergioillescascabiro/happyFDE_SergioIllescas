# PostgreSQL Connection
# Local Mode: postgresql://postgres:postgres@localhost:5433/happyrobot
# Cloud Mode: postgresql://user:pass@cloud-sql-ip:5432/db_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/happyrobot

# Security Keys
AGENT_API_KEY=hr-agent-key-change-in-production
DASHBOARD_TOKEN=hr-dashboard-token-change-in-production

# External Integrations
FMCSA_API_KEY=your-fmcsa-webkey-here
FMCSA_MOCK=false
APP_ENV=development
