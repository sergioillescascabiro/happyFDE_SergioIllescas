# HappyFDE — Terraform Variables
# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored and must NEVER be committed.

# Your GCP project ID (e.g. "my-gcp-project-123")
project_id = "YOUR_GCP_PROJECT_ID"

# GCP region for all resources (Cloud Run, Cloud SQL, Artifact Registry)
region = "us-central1"

# PostgreSQL password for the 'postgres' user on Cloud SQL
db_password = "GENERATE_A_STRONG_PASSWORD"

# Secret key used by the HappyRobot voice agent (X-Agent-Key header)
agent_api_key = "YOUR_HAPPYROBOT_AGENT_API_KEY"

# Secret token used by the dashboard frontend (X-Dashboard-Token header)
dashboard_token = "YOUR_DASHBOARD_TOKEN"
